{
  "name": "@openclaw/friday-channel-next",
  "version": "0.0.1",
  "private": true,
  "description": "OpenClaw Friday Next Apple channel plugin",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:smoke": "node scripts/e2e-smoke.mjs",
    "test:msg-live": "node scripts/message-roundtrip-live.mjs"
  },
  "bin": {
    "install-friday-next": "./install.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "friday-next",
      "label": "Friday Next",
      "selectionLabel": "Friday Next (Apple App)",
      "detailLabel": "Friday Next Apple App",
      "docsPath": "/channels/friday-next",
      "docsLabel": "friday-next",
      "blurb": "Apple app channel with HTTP + SSE v2 streaming.",
      "systemImage": "iphone.radiowaves.left.and.right",
      "markdownCapable": true
    },
    "bundle": {
      "stageRuntimeDependencies": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "chalk": "^5.6.2",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "tslog": "^4.10.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  }
}
