{
  "id": "friday-next",
  "channels": ["friday-next"],
  "contracts": {
    "gatewayMethodDispatch": ["authenticated-request"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "friday-next": {
      "label": "Friday Next",
      "description": "HTTP+SSE channel for the Friday iOS client.",
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "transport": { "type": "string" },
          "pathPrefix": { "type": "string" },
          "historyLimit": { "type": "integer", "minimum": 1, "maximum": 200 },
          "historyDir": { "type": "string" },
          "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
          "authToken": { "type": "string" },
          "cors": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean" },
              "allowOrigin": { "type": "string" }
            }
          },
          "sse": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "keepaliveSec": { "type": "integer", "minimum": 5, "maximum": 120 },
              "backlogPerDevice": { "type": "integer", "minimum": 0, "maximum": 1000 }
            }
          },
          "publicAccess": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean" },
              "relayAddr": { "type": "string" },
              "relayToken": { "type": "string" },
              "subDomainHost": { "type": "string" },
              "subdomain": { "type": "string" },
              "corePort": { "type": "integer", "minimum": 1, "maximum": 65535 }
            }
          }
        }
      },
      "uiHints": {
        "authToken": {
          "label": "Bearer auth token",
          "sensitive": true
        }
      }
    }
  },
  "channelEnvVars": {
    "friday-next": ["FRIDAY_NEXT_AUTH_TOKEN"]
  }
}
